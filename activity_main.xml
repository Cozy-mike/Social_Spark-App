<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Good Morning Section -->
    <TextView
        android:id="@+id/welcomeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Good Morning"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/morningBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Send a 'Good morning' text"
        android:textColor="#FFFFFF"
        android:backgroundTint="#6200EE"/>

    <Button
        android:id="@+id/midMorningBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reach out to a colleague"
        android:textColor="#FFFFFF"
        android:backgroundTint="#6200EE"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/afternoonBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Share a funny meme"
        android:textColor="#FFFFFF"
        android:backgroundTint="#6200EE"
        android:layout_marginTop="10dp"/>

    <EditText
        android:id="@+id/inputText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter your message"
        android:layout_marginTop="15dp"/>

    <Button
        android:id="@+id/snackBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Send a message"
        android:textColor="#FFFFFF"
        android:backgroundTint="#6200EE"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/dinnerBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Call a friend or relative"
        android:textColor="#FFFFFF"
        android:backgroundTint="#6200EE"
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/eveningText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Leave a thoughtful comment"
        android:textSize="18sp"
        android:layout_marginTop="15dp"/>

    <Button
        android:id="@+id/endBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Goodbye. See you soon!"
        android:textColor="#FFFFFF"
        android:backgroundTint="#000000"
        android:layout_marginTop="20dp"/>

</LinearLayout>